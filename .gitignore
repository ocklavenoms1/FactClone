.mono/
data_*/

# Translation artifacts.
*.translation

# OS / editor cruft.
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.vscode/
.idea/

# Claude Code per-project local settings (permissions, tool toggles).
.claude/settings.local.json
